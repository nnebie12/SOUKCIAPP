{
  "expo": {
    "name": "SoukCI",
    "slug": "soukci",
    "version": "1.0.0",
    "description": "Plateforme de découverte de boutiques et commerces en Côte d’Ivoire.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soukci",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8EF"
    },
    "android": {
      "package": "com.soukci.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FFF8EF"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.INTERNET"
      ],
      "edgeToEdgeEnabled": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.soukci.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "SoukCI utilise votre position pour afficher les boutiques proches de vous."
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "SoukCI utilise votre position pour afficher les boutiques proches de vous."
        }
      ],
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportEmail": "privacy@soukci.app",
      "publicWebsiteUrl": "https://soukci.app",
      "privacyPolicyUrl": "https://soukci.app/legal/privacy",
      "dataRightsUrl": "https://soukci.app/legal/data-rights",
      "accountDeletionUrl": "https://soukci.app/legal/delete-account",
      "router": {},
      "eas": {
        "projectId": "e1efebc1-4d0d-4e96-ac82-01f9032c5a12"
      }
    },
    "owner": "dianekassis-organization"
  }
}
